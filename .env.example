DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/linkedin_jobs

REDIS_URL=redis://localhost:6379/0

# LinkedIn OAuth credentials are entered via the app's /setup page after deployment.
# Do NOT put them here. Each deployer registers their own LinkedIn OAuth app at:
# https://developer.linkedin.com/

GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key

# Random 32+ character string — used to encrypt secrets stored in the DB.
SECRET_KEY=change_me_to_a_long_random_string

FRONTEND_URL=https://your-app.vercel.app
ENVIRONMENT=production
